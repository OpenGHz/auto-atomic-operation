<mujoco model="press_three_buttons_gs">
  <compiler meshdir="../../../meshes"/>

  <visual>
    <map znear="0.001"/>
  </visual>

  <asset>
    <!-- meshdir resolved to assets/meshes/ via robotiq.xml compiler -->
    <mesh name="blue_button_mesh"  file="press_three_buttons/blue_button/blue_button_mesh.obj"/>
    <mesh name="green_button_mesh" file="press_three_buttons/green_button/green_button_mesh.obj"/>
    <mesh name="pink_button_mesh"  file="press_three_buttons/pink_button/pink_button_mesh.obj"/>

    <material name="blue_button_mat"  rgba="0.10 0.35 0.95 1" reflectance="0.2"/>
    <material name="green_button_mat" rgba="0.10 0.80 0.25 1" reflectance="0.2"/>
    <material name="pink_button_mat"  rgba="0.95 0.25 0.65 1" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light name="demo_light" pos="0.45 0.06 1.5" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.85 0.85 0.85 1"/>

    <!-- Table: matches background GS coordinate frame (table30_01_press_three_buttons.xml).
         Geom center at (0.45, 0.06, 0.0642), half-height=0.01 → top surface z=0.0742. -->
    <geom name="table" pos="0.45 0.06 0.0642" size="0.33 0.525 0.01" type="box"
          contype="1" conaffinity="1" rgba="0.6 0.45 0.3 1"/>

    <!-- ── BUTTON BODIES (two-layer structure) ─────────────────────────────────
         Two nested bodies are used to reconcile GS body naming and physics:

           button_*_gs  (outer, no joint → static, identity orientation)
             World pos matches the PLY capture frame.
             PLY data is stored in upright canonical frame (no rotation needed).
             body_gaussians in YAML maps THIS body to the .ply file.

           button_*  (inner, child of outer)
             pos="0 0 0.012" places the cylinder centre above the outer body origin.
             YAML stages target THIS body (object: button_*) for operation poses.

         Button positions from the reference Franka scene (world frame):
           blue:  (0.443,  0.0197,  0.0812)
           green: (0.5485, -0.0512, 0.0812)
           pink:  (0.532,  0.127,   0.0812)                                     -->

    <!-- BLUE -->
    <body name="button_blue_gs" pos="0.443 0.0197 0.0812">
      <body name="button_blue" pos="0 0 0.012">
        <geom name="button_blue_col" type="cylinder" size="0.040 0.02"
              mass="0.1" rgba="0 0 0 0" contype="1" conaffinity="1"/>
        <geom name="button_blue_vis" type="mesh" mesh="blue_button_mesh" material="blue_button_mat"
              euler="0.959931089 0.052359878 0" density="0" contype="0" conaffinity="0" group="1"/>
        <site name="button_blue_site" pos="0 0 0" size="0.004" rgba="0 0 1 0"/>
      </body>
    </body>

    <!-- GREEN -->
    <body name="button_green_gs" pos="0.5485 -0.0512 0.0812">
      <body name="button_green" pos="0 0 0.012">
        <geom name="button_green_col" type="cylinder" size="0.040 0.02"
              mass="0.1" rgba="0 0 0 0" contype="1" conaffinity="1"/>
        <geom name="button_green_vis" type="mesh" mesh="green_button_mesh" material="green_button_mat"
              euler="0.959931089 0.052359878 0" density="0" contype="0" conaffinity="0" group="1"/>
        <site name="button_green_site" pos="0 0 0" size="0.004" rgba="0 1 0 0"/>
      </body>
    </body>

    <!-- PINK -->
    <body name="button_pink_gs" pos="0.532 0.127 0.0812">
      <body name="button_pink" pos="0 0 0.012">
        <geom name="button_pink_col" type="cylinder" size="0.040 0.02"
              mass="0.1" rgba="0 0 0 0" contype="1" conaffinity="1"/>
        <geom name="button_pink_vis" type="mesh" mesh="pink_button_mesh" material="pink_button_mat"
              euler="0.959931089 0.052359878 0" density="0" contype="0" conaffinity="0" group="1"/>
        <site name="button_pink_site" pos="0 0 0" size="0.004" rgba="1 0 1 0"/>
      </body>
    </body>

    <!-- Cameras matching the background GS coordinate frame (same pos/xyaxes as
         table30_01_press_three_buttons.xml so background.ply aligns correctly). -->
    <camera name="env1_cam" pos="1.042 -0.235 0.660"
            xyaxes="0.364 0.931 -0.000 -0.597 0.234 0.767" fovy="45"/>
    <camera name="env0_cam" pos="0.488 1.0 0.6"
            xyaxes="-0.9994 0.0338 0.0000 -0.0107 -0.3168 0.9484" fovy="45"/>
  </worldbody>

</mujoco>
