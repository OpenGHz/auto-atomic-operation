<mujoco model="open_door_demo">
  <!-- Robot-less scene. Compose via env.robot_paths in the task YAML. -->

  <statistic center="0.3 0 0.4" extent="1"/>

  <option timestep="0.005" iterations="5" ls_iterations="8" integrator="implicitfast" noslip_iterations="2">
    <flag eulerdamp="disable"/>
  </option>

  <custom>
    <numeric data="12" name="max_contact_points"/>
  </custom>

  <visual>
    <headlight diffuse=".8 .8 .8" ambient=".2 .2 .2" specular="1 1 1"/>
    <rgba force="1 0 0 1"/>
    <global azimuth="-40" elevation="-30"/>
    <map force="0.01" znear="0.001"/>
    <quality shadowsize="8192"/>
    <scale contactwidth="0.075" contactheight="0.025" forcewidth="0.05" com="0.05" framewidth="0.01" framelength="0.2"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="1 1 1" rgb2="1 1 1" width="800" height="800"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="1 1 1" rgb2="1 1 1" markrgb="0 0 0" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0"/>
  </asset>

  <worldbody>
    <light name="scene_light" pos="0 0 1.5" dir="0 0 -1" directional="true"/>

    <body name="ground" pos="1 0 -1">
      <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" contype="1"/>
    </body>

    <!-- Flanking cameras on the robot side, symmetric about the handle
         world y=0.22 with 1 m half-separation. Both look at
         (1.54, 0.22, -0.12) (handle + a small up-bias so the gripper and
         handle both fit in frame). env1_cam = "right" (world -y side),
         env0_cam = "left" (world +y side). fovy=30° tightens framing on
         the handle/gripper interaction so the GS background's limited
         wall coverage stays inside the frame (no black void at edges). -->
    <camera name="env1_cam" pos="0.440 -0.780 0.300" xyaxes="0.672673 -0.739940 0.000000 0.201175 0.182886 0.962331" fovy="30"/>
    <camera name="env0_cam" pos="0.440  1.220 0.300" xyaxes="-0.672673 -0.739940 0.000000 0.201175 -0.182886 0.962331" fovy="30"/>
    <!-- env2_cam: centred on door panel width (world y=0.552), 2.04 m in
         front of the door and 1.5 m high, pitched ~39° down at the door
         panel centre (1.54, 0.55, -0.18). Yaw ≈ 0 so the door reads
         symmetrically in the frame. Gives a top-down overview that
         complements the two side cameras. -->
    <camera name="env2_cam" pos="-0.500  0.5520 1.500" xyaxes="-0.000980 -1.000000 0.000000 0.635707 -0.000623 0.771930" fovy="30"/>
    <!-- <camera name="topside" pos="0.740 0.127 0.060" xyaxes="0.142 -0.990 0.000 0.113 0.016 0.993"/> -->

    <body name="door_frame_physics" pos="1.540000000 0.100000000 -1.000000000" quat="0.707106781 0.000000000 0.000000000 0.707106781">
      <geom name="door_frame_physics_left_geom" type="box" pos="0.000000000 0.000000000 0.830000000" size="0.025000000 0.025000000 0.830000000" rgba="0.35 0.25 0.15 1" contype="1" conaffinity="1"/>
      <geom name="door_frame_physics_right_geom" type="box" pos="0.900000000 0.000000000 0.830000000" size="0.025000000 0.025000000 0.830000000" rgba="0.35 0.25 0.15 1" contype="1" conaffinity="1"/>
      <geom name="door_frame_physics_top_geom" type="box" pos="0.450000000 0.000000000 1.655000000" size="0.475000000 0.025000000 0.025000000" rgba="0.35 0.25 0.15 1" contype="1" conaffinity="1"/>

      <body name="door_body_phys" pos="0.840000000 0.000000000 0.000000000">
        <joint name="door_hinge" type="hinge" pos="0 0 0" axis="0 0 1" limited="true" range="-1.57 1.57 " damping="5.0" frictionloss="5.0" armature="0.05"/>
        <inertial pos="-0.420000000 0.000000000 0.815000000" mass="6.0" diaginertia="0.2 0.2 0.2"/>
        <geom name="door_panel_geom" type="box" pos="-0.390000000 0.000000000 0.815000000" size="0.420000000 0.020000000 0.815000000" rgba="0.65 0.50 0.35 1" density="350" contype="1" conaffinity="1" friction="0.8 0.1 0.1"/>
        <site name="door_push_site" pos="-0.729500000 0.022000000 0.825000000" size="0.012" rgba="0.2 0.2 1 1"/>

        <body name="handle_body_phys" pos="-0.719500000 0.000000000 0.825000000">
          <inertial pos="0 0 0" mass="0.05" diaginertia="0.00005 0.00005 0.00005"/>
          <geom name="handle_spindle_geom" type="cylinder" fromto="0 -0.042 0 0 0.042 0" size="0.010" rgba="0.55 0.55 0.55 1" contype="1" conaffinity="1"/>
          <geom name="handle_plate_front_geom" type="box" pos="0 0.054 0" size="0.032 0.022 0.102" rgba="0.70 0.82 0.85 0.95" contype="1" conaffinity="1"/>
          <geom name="handle_plate_back_geom" type="box" pos="0 -0.054 0" size="0.032 0.022 0.102" rgba="0.70 0.82 0.85 0.95" contype="1" conaffinity="1"/>
          <site name="handle_axis_site" pos="0 0 0" size="0.010" rgba="1 1 0 0.8"/>

          <body name="handle_lever_body" pos="0 0 -0.02">
            <inertial pos="0.08 0 0" mass="0.05" diaginertia="0.0001 0.0001 0.0001"/>
            <joint name="handle_hinge" type="hinge" pos="0 0 0" axis="0 1 0" limited="true" range="-0.20 0.80" damping="0.4" frictionloss="0.02" armature="0.0005" springref="0" stiffness="0.5"/>
            <geom name="handle_lever_front_geom" type="capsule" fromto="0.010 0.080 0 0.175 0.080 0" size="0.012" rgba="0.50 0.90 0.95 1" contype="1" conaffinity="1"/>
            <geom name="handle_lever_back_geom" type="capsule" fromto="0.010 -0.080 0 0.175 -0.080 0" size="0.012" rgba="0.50 0.90 0.95 1" contype="1" conaffinity="1"/>
            <!-- front sites: world-aligned (cancels parent door_frame_physics +90° z) -->
            <!-- back sites: mirrored from front via 180° rotation about world z -->
            <site name="handle_tip_front_site" pos="0.175 0.080 0.000" quat="0.707106781 0 0 -0.707106781" size="0.010" rgba="1 0.4 0.2 1"/>
            <site name="handle_tip_back_site" pos="0.175 -0.080 0.000" quat="0.707106781 0 0  0.707106781" size="0.010" rgba="1 0.4 0.2 1"/>
            <site name="handle_grasp_front_site" pos="0.095 0.055 0.000" quat="0.707106781 0 0 -0.707106781" size="0.012" rgba="1 0.2 0.2 1"/>
            <site name="handle_grasp_back_site" pos="0.095 -0.055 0.000" quat="0.707106781 0 0  0.707106781" size="0.012" rgba="1 0.2 0.2 1"/>
            <site name="handle_press_front_site" pos="0.095 0.080 0.000" quat="0.707106781 0 0 -0.707106781" size="0.012" rgba="0.2 1 0.2 1"/>
            <site name="handle_press_back_site" pos="0.095 -0.080 0.000" quat="0.707106781 0 0  0.707106781" size="0.012" rgba="0.2 1 0.2 1"/>

            <!-- GS frame body for handle/knob PLY -->
            <body name="handle_gs_frame" pos="0.270651190 1.595000000 0.058962200" quat="0.023543636 -0.014802135 0.716127885 -0.697414831"/>
          </body>
        </body>

        <!-- GS frame body for door PLY -->
        <body name="door_gs_frame" pos="-0.448848810 1.595000000 0.863962200" quat="0.023543636 -0.014802135 0.716127885 -0.697414831">
          <body name="door_body" pos="0 0 0"/>
        </body>
      </body>
    </body>
    <!-- GS frame body for background PLY -->
    <body name="bg_gs_frame" pos="-0.105000000 0.491151190 -0.136037800" quat="0.509794620 -0.516845570 0.495912190 -0.476498890"/>
  </worldbody>
</mujoco>
