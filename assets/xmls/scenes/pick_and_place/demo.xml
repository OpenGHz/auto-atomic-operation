<mujoco model="pick_place_demo">
  <include file="../../robots/robotiq.xml"/>

  <visual>
    <map znear="0.001"/>
  </visual>

  <worldbody>
    <light name="demo_light" pos="0 0 1.5" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.85 0.85 0.85 1"/>

    <!-- table half-height=0.03, sits on floor: center z=0.03, top surface z=0.06 -->
    <body name="table" pos="0 0 0.03">
      <geom name="table_top" type="box" size="0.28 0.22 0.03" rgba="0.6 0.45 0.3 1"/>
    </body>

    <!-- ===== 桌面方向指示装饰 ===== -->
    <!-- 4色象限填色：NE红 / NW绿 / SW蓝 / SE黄，一眼识别方位 -->
    <geom name="deco_q_NE" type="box" pos=" 0.143  0.113 0.0605" size="0.137 0.107 0.0005" rgba="0.85 0.25 0.25 1" contype="0" conaffinity="0"/>
    <geom name="deco_q_NW" type="box" pos="-0.143  0.113 0.0605" size="0.137 0.107 0.0005" rgba="0.20 0.70 0.30 1" contype="0" conaffinity="0"/>
    <geom name="deco_q_SW" type="box" pos="-0.143 -0.113 0.0605" size="0.137 0.107 0.0005" rgba="0.20 0.35 0.85 1" contype="0" conaffinity="0"/>
    <geom name="deco_q_SE" type="box" pos=" 0.143 -0.113 0.0605" size="0.137 0.107 0.0005" rgba="0.85 0.70 0.10 1" contype="0" conaffinity="0"/>
    <!-- 白色十字分隔线 -->
    <geom name="deco_div_x" type="box" pos="0 0 0.0615" size="0.275 0.006 0.0005" rgba="0.95 0.95 0.95 1" contype="0" conaffinity="0"/>
    <geom name="deco_div_y" type="box" pos="0 0 0.0615" size="0.006 0.215 0.0005" rgba="0.95 0.95 0.95 1" contype="0" conaffinity="0"/>
    <!-- 各象限内的对角 X 纹（奇奇怪怪的图案） -->
    <geom name="deco_x1_NE" type="box" pos=" 0.143  0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0  0.7854" rgba="1.00 0.65 0.65 1" contype="0" conaffinity="0"/>
    <geom name="deco_x2_NE" type="box" pos=" 0.143  0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0 -0.7854" rgba="1.00 0.65 0.65 1" contype="0" conaffinity="0"/>
    <geom name="deco_x1_NW" type="box" pos="-0.143  0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0  0.7854" rgba="0.55 0.90 0.65 1" contype="0" conaffinity="0"/>
    <geom name="deco_x2_NW" type="box" pos="-0.143  0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0 -0.7854" rgba="0.55 0.90 0.65 1" contype="0" conaffinity="0"/>
    <geom name="deco_x1_SW" type="box" pos="-0.143 -0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0  0.7854" rgba="0.55 0.60 0.95 1" contype="0" conaffinity="0"/>
    <geom name="deco_x2_SW" type="box" pos="-0.143 -0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0 -0.7854" rgba="0.55 0.60 0.95 1" contype="0" conaffinity="0"/>
    <geom name="deco_x1_SE" type="box" pos=" 0.143 -0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0  0.7854" rgba="0.95 0.85 0.40 1" contype="0" conaffinity="0"/>
    <geom name="deco_x2_SE" type="box" pos=" 0.143 -0.113 0.0612" size="0.088 0.004 0.0004" euler="0 0 -0.7854" rgba="0.95 0.85 0.40 1" contype="0" conaffinity="0"/>
    <!-- 四角圆形标识（颜色与象限一致） -->
    <geom name="deco_corner_NE" type="cylinder" pos=" 0.252  0.193 0.063" size="0.016 0.002" rgba="0.85 0.25 0.25 1" contype="0" conaffinity="0"/>
    <geom name="deco_corner_NW" type="cylinder" pos="-0.252  0.193 0.063" size="0.016 0.002" rgba="0.20 0.70 0.30 1" contype="0" conaffinity="0"/>
    <geom name="deco_corner_SW" type="cylinder" pos="-0.252 -0.193 0.063" size="0.016 0.002" rgba="0.20 0.35 0.85 1" contype="0" conaffinity="0"/>
    <geom name="deco_corner_SE" type="cylinder" pos=" 0.252 -0.193 0.063" size="0.016 0.002" rgba="0.85 0.70 0.10 1" contype="0" conaffinity="0"/>
    <!-- 四边中点白色刻度点（罗盘感） -->
    <geom name="deco_tick_N" type="cylinder" pos=" 0.000  0.207 0.063" size="0.010 0.002" rgba="0.95 0.95 0.95 1" contype="0" conaffinity="0"/>
    <geom name="deco_tick_S" type="cylinder" pos=" 0.000 -0.207 0.063" size="0.010 0.002" rgba="0.95 0.95 0.95 1" contype="0" conaffinity="0"/>
    <geom name="deco_tick_E" type="cylinder" pos=" 0.267  0.000 0.063" size="0.010 0.002" rgba="0.95 0.95 0.95 1" contype="0" conaffinity="0"/>
    <geom name="deco_tick_W" type="cylinder" pos="-0.267  0.000 0.063" size="0.010 0.002" rgba="0.95 0.95 0.95 1" contype="0" conaffinity="0"/>
    <!-- 中心白点 -->
    <geom name="deco_center" type="cylinder" pos="0 0 0.064" size="0.012 0.002" rgba="0.95 0.95 0.95 1" contype="0" conaffinity="0"/>
    <!-- +X 方向箭头（红色胶囊 + 端部圆点） -->
    <geom name="deco_xarrow"     type="capsule"  fromto="0.015 0 0.0630  0.210 0 0.0630" size="0.004" rgba="1.00 0.50 0.50 1" contype="0" conaffinity="0"/>
    <geom name="deco_xarrow_dot" type="cylinder" pos="0.222 0 0.065"    size="0.009 0.003"             rgba="1.00 0.50 0.50 1" contype="0" conaffinity="0"/>
    <!-- +Y 方向箭头（绿色胶囊 + 端部圆点） -->
    <geom name="deco_yarrow"     type="capsule"  fromto="0 0.015 0.0630  0 0.175 0.0630" size="0.004" rgba="0.40 0.90 0.50 1" contype="0" conaffinity="0"/>
    <geom name="deco_yarrow_dot" type="cylinder" pos="0 0.187 0.065"    size="0.009 0.003"             rgba="0.40 0.90 0.50 1" contype="0" conaffinity="0"/>
    <!-- 对角波卡点：每象限放一个对比色小圆点，增加趣味感 -->
    <geom name="deco_dot_NE" type="cylinder" pos=" 0.210  0.170 0.064" size="0.010 0.002" rgba="0.20 0.35 0.85 1" contype="0" conaffinity="0"/>
    <geom name="deco_dot_NW" type="cylinder" pos="-0.210  0.170 0.064" size="0.010 0.002" rgba="0.85 0.25 0.25 1" contype="0" conaffinity="0"/>
    <geom name="deco_dot_SW" type="cylinder" pos="-0.210 -0.170 0.064" size="0.010 0.002" rgba="0.85 0.70 0.10 1" contype="0" conaffinity="0"/>
    <geom name="deco_dot_SE" type="cylinder" pos=" 0.210 -0.170 0.064" size="0.010 0.002" rgba="0.20 0.70 0.30 1" contype="0" conaffinity="0"/>

    <!-- pedestal sits on table top (z=0.06), half-height=0.04 → center z=0.10 -->
    <body name="target_pedestal" pos="0.12 0 0.10">
      <geom name="target_pedestal_geom" type="box" size="0.035 0.035 0.04" rgba="0.35 0.45 0.8 1"/>
      <site name="target_pedestal_site" pos="0 0 0" size="0.004" rgba="1 0 0 0"/>
    </body>

    <!-- Front camera: looking from -Y toward the task area -->
    <camera name="env1_cam" pos="0 -0.8 0.5" xyaxes="1 0 0 0 0.447 0.894" fovy="45"/>
    <!-- Side camera: looking from +X toward the task area -->
    <camera name="env0_cam" pos="0.9 0 0.5" xyaxes="0 1 0 -0.406 0 0.914" fovy="45"/>

    <!-- source block sits on table top (z=0.06), half-height=0.018 → center z=0.078 -->
    <body name="source_block" pos="-0.04 0 0.078">
      <freejoint name="source_block_joint"/>
      <geom name="source_block_geom" type="box" size="0.018 0.018 0.018" mass="0.08" friction="1.2 0.05 0.01" rgba="0.85 0.2 0.2 1"/>
      <site name="source_block_site" pos="0 0 0" size="0.004" rgba="1 0 0 0"/>
    </body>
  </worldbody>

  <keyframe>
    <key
      qpos="
         0 0 0.4 1 0 0 0
         0.00522882 0.00541525 0.00562153 0.00529892 0.00548528 0.00569143
         -0.04 0 0.078 1 0 0 0"
      ctrl="0"
    />
  </keyframe>
</mujoco>
