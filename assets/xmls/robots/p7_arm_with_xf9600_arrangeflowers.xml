      <geom name="table" pos="0 0 -0.5" size="0.15 0.2 0.5" type="box" contype="1"/>

      <geom type="mesh" rgba="0.75294 0.75294 0.75294 1" mesh="base_link" contype="0" conaffinity="0"/>

